    .chiasm-line:hover{transform:translateX(8px);box-shadow:0 2px 8px var(--page-accent-glow)}
    .pair-1{background:linear-gradient(90deg,rgba(43,94,167,.14),rgba(43,94,167,.05));border-left:4px solid #2B5EA7}
    .pair-2{background:linear-gradient(90deg,rgba(212,169,64,.18),rgba(212,169,64,.06));border-left:4px solid #D4A940}
