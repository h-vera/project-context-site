    /* ── Quick nav pills ── */
    .quick-nav-pills{margin:0 0 2rem;padding:1rem 1.25rem;background:linear-gradient(135deg,rgba(43,94,167,.04),rgba(212,169,64,.03));border:1.5px solid rgba(43,94,167,.12);border-radius:14px;display:flex;align-items:center;gap:.75rem;position:relative;overflow:hidden}
    .quick-nav-pills::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--page-accent),var(--page-accent-light),var(--page-accent));border-radius:14px 14px 0 0;opacity:.4}
    .quick-nav-label{flex-shrink:0;font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--page-accent-dark);opacity:.6;padding-right:.5rem;border-right:2px solid rgba(43,94,167,.15)}
