    .nav-pill:hover{color:var(--page-accent-dark);background:linear-gradient(135deg,rgba(43,94,167,.08),rgba(212,169,64,.05));border-color:var(--page-accent);box-shadow:0 3px 10px var(--page-accent-glow);transform:translateY(-2px)}

    /* ── Dark feature (enhanced) ── */
    .dark-feature{background:linear-gradient(135deg,#0C1929 0%,#1A3D6E 40%,#122B4D 100%);border-radius:16px;padding:2rem;color:#EEF2F7;position:relative;overflow:hidden;margin:1.5rem 0;transition:all .3s ease}
    .dark-feature::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 15% 0%,rgba(255,255,255,.06) 0%,transparent 55%),radial-gradient(circle at 100% 100%,rgba(212,169,64,.12) 0%,transparent 65%);pointer-events:none}
