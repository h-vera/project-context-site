    .chiasm-center:hover{box-shadow:0 8px 24px rgba(43,94,167,.35);transform:scale(1.02)}

    /* ── Timeline buttons ── */
    .stl-btn{transition:all .25s ease!important}
    .stl-btn:hover{transform:translateY(-3px)!important;box-shadow:0 4px 14px var(--page-accent-glow)!important}

    /* ── Transition steps ── */
    .trans-step{transition:all .3s ease}
