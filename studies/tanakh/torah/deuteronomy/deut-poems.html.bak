  <script type="module">import NavigationComponent from '/assets/js/nav-component.js';const navigation = new NavigationComponent({currentPage:'studies/tanakh/torah/deuteronomy/deut-poems',hubType:'tanakh'});</script>
  <script src="/assets/js/character-page-v5-8.js" defer></script>
  <script>
  // ══════════════════════════════════════════
  // SONG STAGE INTERACTIVE
  // ══════════════════════════════════════════
  const songStages={rock:'<strong style="color:var(--page-accent-dark);">Yahweh the Rock (32:1–4):</strong> The Song begins by declaring God\'s perfect character. He is the faithful Rock whose works are perfect, whose ways are just. Heaven and earth are called to witness this covenant.',rebel:'<strong style="color:var(--page-accent-dark);">Israel\'s Corruption (32:5–18):</strong> Despite God\'s faithfulness, Israel turns to other gods. The poem accuses Israel of forgetting the God who found them in the wilderness, carried them like an eagle, and gave them life. They grew fat on blessing and kicked against their maker — the ironic reversal embedded in the name <em>Jeshurun</em> ("upright one") used at 32:15.',judgment:'<strong style="color:var(--page-accent-dark);">Divine Judgment (32:19–25):</strong> God responds by hiding his face and allowing disaster to fall. This is the center of the chiasm — the most devastating moment. Yahweh\'s controversy with his people reaches its peak.',nations:'<strong style="color:var(--page-accent-dark);">Nations Rise (32:26–35):</strong> Foreign nations become instruments of divine discipline, but God warns them against arrogance. Their "rock" is not like Israel\'s Rock. They too will be measured and found wanting. "Vengeance is mine, and recompense" (32:35) — quoted later by both Paul (Rom 12:19) and the author of Hebrews (10:30).',restore:'<strong style="color:var(--page-accent-dark);">God Restores (32:36–43):</strong> Ultimately Yahweh vindicates his servants and defeats their enemies. The song ends with atonement for the land and hope for future redemption. "Rejoice, O nations, with his people" (32:43) — Paul quotes this as proof that the nations were always meant to share in Israel\'s restoration (Rom 15:10). In Revelation 15:3, the redeemed sing this song at the end of all things.'};
  function showSongStage(btn,key){document.querySelectorAll('.stl-btn').forEach(b=>{b.style.borderColor='var(--page-accent-border)';b.style.background='white'});btn.style.borderColor='var(--page-accent)';btn.style.background='var(--page-accent-bg)';document.getElementById('song-stage-display').innerHTML='<p style="margin:0;font-size:.88rem;color:#4A5E78;line-height:1.6;">'+songStages[key]+'</p>';}

  // ══════════════════════════════════════════
  // ANIMATION ENGINE — Poems Page
  // ══════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    var stagger = 120;

    // 1. Every theology-card gets section-level entrance
    document.querySelectorAll('.theology-card').forEach(function(card) {
      card.classList.add('anim-section');
    });

    // 2. Echo cards — staggered
    document.querySelectorAll('.echo-card').forEach(function(card, i) {
      card.classList.add('anim-card');
      card.style.transitionDelay = (i % 9) * stagger + 'ms';
    });

    // 3. Chiasm lines — staggered flow
    document.querySelectorAll('.chiasm-line, .chiasm-center').forEach(function(line, i) {
      line.classList.add('anim-flow');
      line.style.transitionDelay = i * 100 + 'ms';
    });

    // 4. Transition steps — sequential flow
    document.querySelectorAll('.trans-step').forEach(function(el, i) {
      el.classList.add('anim-flow');
      el.style.transitionDelay = i * 120 + 'ms';
    });

    // 5. Timeline buttons — staggered
    document.querySelectorAll('.stl-btn').forEach(function(btn, i) {
      btn.classList.add('anim-card');
      btn.style.transitionDelay = i * 100 + 'ms';
    });

    // 6. Table rows
    document.querySelectorAll('table tbody tr').forEach(function(row, i) {
      row.classList.add('anim-row');
      row.style.transitionDelay = i * stagger + 'ms';
    });

    // 7. Navigation cards
    document.querySelectorAll('#navigation a[style]').forEach(function(card, i) {
      card.classList.add('anim-card');
      card.style.transitionDelay = i * stagger + 'ms';
    });

    // 8. Panels
    document.querySelectorAll('.panel').forEach(function(panel, i) {
      panel.classList.add('anim-card');
      panel.style.transitionDelay = i * stagger + 'ms';
    });

    // IntersectionObserver
    var selector = '.anim-card,.anim-section,.anim-flow,.anim-row';
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('anim-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll(selector).forEach(function(el) {
      observer.observe(el);
    });

    console.log('Poems page animation engine: active (' + document.querySelectorAll(selector).length + ' elements)');
  });
  </script>
</body>
</html>