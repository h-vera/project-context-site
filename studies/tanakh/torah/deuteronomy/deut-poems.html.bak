    /* ── Echo card ── */
    .echo-card{background:white;border:1px solid var(--page-accent-border);border-radius:12px;padding:1.25rem;border-top:4px solid var(--page-accent);transition:all .3s ease;position:relative;overflow:hidden}
    .echo-card::after{content:'';position:absolute;inset:-2px;background:linear-gradient(135deg,rgba(43,94,167,.1),rgba(212,169,64,.08));border-radius:12px;z-index:-1;opacity:0;transition:opacity .3s ease}
    .echo-card:hover{border-color:var(--page-accent);box-shadow:0 8px 24px var(--page-accent-glow);transform:translateY(-6px) scale(1.02)}
    .echo-card:hover::after{opacity:.35}
