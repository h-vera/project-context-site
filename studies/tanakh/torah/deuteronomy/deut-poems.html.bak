    .anim-section{opacity:0;transform:translateY(24px);transition:opacity .7s ease-out,transform .7s ease-out}
    .anim-section.anim-visible{opacity:1;transform:translateY(0);transition:transform .3s ease,box-shadow .3s ease}
    .anim-section h3{opacity:0;transform:translateX(-24px);transition:opacity .5s ease-out,transform .5s ease-out}
    .anim-section.anim-visible h3{opacity:1;transform:translateX(0)}
    .anim-section>p{opacity:0;transform:translateX(-14px);transition:opacity .5s ease-out,transform .5s ease-out}
    .anim-section.anim-visible>p:nth-of-type(1){opacity:1;transform:translateX(0);transition-delay:.1s}
    .anim-section.anim-visible>p:nth-of-type(2){opacity:1;transform:translateX(0);transition-delay:.2s}
    .anim-section .key-insight,.anim-section .wisdom-callout{opacity:0;transform:translateX(-20px);transition:opacity .5s ease-out,transform .5s ease-out}
    .anim-section.anim-visible .key-insight,.anim-section.anim-visible .wisdom-callout{opacity:1;transform:translateX(0);transition-delay:.4s}
    .anim-section .dark-feature{opacity:0;transform:translateY(16px) scale(.98);transition:opacity .6s ease-out,transform .6s ease-out}
    .anim-section.anim-visible .dark-feature{opacity:1;transform:translateY(0) scale(1);transition-delay:.5s}
    .anim-section .panel{opacity:0;transform:translateY(14px);transition:opacity .5s ease-out,transform .5s ease-out}
    .anim-section.anim-visible .panel:nth-child(1){opacity:1;transform:translateY(0);transition-delay:.15s}
    .anim-section.anim-visible .panel:nth-child(2){opacity:1;transform:translateY(0);transition-delay:.3s}
    .anim-card{opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease}
    .anim-card.anim-visible{opacity:1;transform:translateY(0)}
    .anim-flow{opacity:0;transform:translateX(-12px);transition:opacity .4s ease,transform .4s ease}
    .anim-flow.anim-visible{opacity:1;transform:translateX(0)}
    .anim-row{opacity:0;transform:translateY(8px);transition:opacity .45s ease,transform .45s ease}
    .anim-row.anim-visible{opacity:1;transform:translateY(0)}
    .anim-section.anim-visible .key-insight strong:first-child{background:linear-gradient(120deg,transparent 0%,rgba(212,169,64,.2) 50%,transparent 100%);background-size:200% 100%;animation:highlightSweep 2s ease-out .6s 1;padding:0 .2rem}

    @keyframes heroBreathe{0%,100%{opacity:.04}50%{opacity:.08}}
    @keyframes highlightSweep{0%{background-position:-100% 0}50%{background-position:0 0}100%{background-position:100% 0}}

