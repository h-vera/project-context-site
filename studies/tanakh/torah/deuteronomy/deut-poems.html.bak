      .quick-nav-scroll{flex-wrap:nowrap;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:.25rem;width:100%}
      .quick-nav-scroll::-webkit-scrollbar{display:none}
    }

    @media(prefers-reduced-motion:reduce){
      .anim-section,.anim-card,.anim-flow,.anim-row{opacity:1!important;transform:none!important;transition:none!important}
      .anim-section h3,.anim-section>p,.anim-section .key-insight,.anim-section .dark-feature,.anim-section .panel{opacity:1!important;transform:none!important;transition:none!important;animation:none!important}
      .page-header-banner::after{animation:none!important}
      .dark-feature:hover,.panel:hover,.echo-card:hover,.stl-btn:hover,.trans-step:hover,#navigation a:hover{transform:none!important}
    }
  </style>
